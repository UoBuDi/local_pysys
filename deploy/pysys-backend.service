[Unit]
Description=PySys Backend Service (FastAPI)
After=network.target mysql.service

[Service]
Type=simple
User=www
Group=www
WorkingDirectory=/www/wwwroot/pysys-backend/backend
ExecStart=/www/server/panel/pyenv/bin/python3 -m uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2
Restart=always
RestartSec=5
StandardOutput=append:/www/wwwroot/pysys-backend/logs/uvicorn.log
StandardError=append:/www/wwwroot/pysys-backend/logs/uvicorn-error.log

[Install]
WantedBy=multi-user.target
